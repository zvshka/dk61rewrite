# discord
BOT_TOKEN="YOUR_BOT_TOKEN"
TEST_GUILD_ID="TEST_GUILD_ID"
BOT_OWNER_ID="YOUR_DISCORD_ID"


# database
# DATABASE_HOST="database" # if you use docker-compose, it should be the name of the service hosting the database
# DATABASE_PORT=5432
# DATABASE_NAME="tscord_bot"
# DATABASE_USER="tscord"
# DATABASE_PASSWORD="tscord123"

# api
# API_PORT=4000
# API_ADMIN_TOKEN="PUT_A_RANDOM_TOKEN_HERE" # you can generate one here -> https://www.uuidgenerator.net/version1 

# external services
# IMGUR_CLIENT_ID="YOUR_IMGUR_CLIENT_ID"

# llm (ai)
# LLM_PROVIDER="local" # "local" for LM Studio / llama.cpp, "deepseek" for DeepSeek API
# LLM_LOCAL_URL="http://localhost:1234/v1" # base URL for local LLM (OpenAI-compatible)
# LLM_LOCAL_MODEL="" # model name for local provider (optional)
# LLM_DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
# LLM_DEEPSEEK_MODEL="deepseek-chat"
# LLM_MAX_TOKENS=2048
# LLM_TEMPERATURE=0.7
# LLM_CONTEXT_LIMIT=10 # number of messages to keep in conversation history
# LLM_RATE_LIMIT_MAX=10 # max requests per window
# LLM_RATE_LIMIT_WINDOW=60000 # window in ms (60000 = 1 minute)

# web search
# SEARCH_PROVIDER="microservice" # "microservice" (Python microservice) or "custom"
# SEARCH_SERVICE_URL="http://localhost:8020" # URL of the Python search microservice
# SEARCH_DELAY="1.5" # optional: min interval (seconds) between requests
# SEARCH_CUSTOM_URL="" # custom search API URL (optional)
# SEARCH_CUSTOM_API_KEY="" # custom search API key (optional)
