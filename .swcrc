{
  "$schema": "https://json.schemastore.org/swcrc",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "target": "es2024"
  },
  "module": {
    "type": "commonjs"
  },
  "sourceMaps": "inline",
  "exclude": ["node_modules", "build", "tests"]
}
