// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Guild entity
model Guild {
  id           String  @id
  prefix       String? @default(".")
  quotesPrefix String  @default("\\") @map("quotes_prefix")

  starboardEmoji   String? @default("⭐") @map("starboard_emoji")
  starboardChannel String? @map("starboard_channel")
  starboardCount   Int     @default(3) @map("starboard_count")
  proposalChannel  String? @map("proposal_channel")

  deleted Boolean @default(false)

  lastInteract DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  starredMessages StarredMessage[]
  rssFeeds        RssFeed[]
  welcomeImages   WelcomeImage[]
  answers         PingAnswer[]
  welcomeMessages WelcomeMessage[]
  proposals       Proposal[]
}

model User {
  id String @id

  lastInteract DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  proposals Proposal[]

  userFor     Proposal[] @relation(name: "usersFor")
  userAgainst Proposal[] @relation(name: "usersAgainst")
}

model Image {
  id String @id @default(nanoid())

  filename   String
  basePath   String   @default("")
  url        String
  size       Int
  tags       String[]
  hash       String
  deleteHash String

  lastInteract DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Stat {
  id             String @id @default(nanoid())
  type           String
  value          String
  additionalData Json?

  createdAt DateTime @default(now())
}

model StarredMessage {
  guild            Guild  @relation(fields: [guildId], references: [id])
  guildId          String
  starredMessageId String
  botMessageId     String

  @@id([guildId, starredMessageId])
}

model WelcomeImage {
  id  Int    @id @default(autoincrement())
  url String

  isApi       Boolean? @default(false)
  pathToImage String?

  guild   Guild  @relation(fields: [guildId], references: [id])
  guildId String
}

model WelcomeMessage {
  id      Int    @id @default(autoincrement())
  text    String
  guild   Guild  @relation(fields: [guildId], references: [id])
  guildId String
}

model PingAnswer {
  id   Int    @id @default(autoincrement())
  text String

  guild   Guild  @relation(fields: [guildId], references: [id])
  guildId String
}

model Proposal {
  id          Int    @id @default(autoincrement())
  text        String
  description String

  author User  @relation(fields: [authorId], references: [id])
  guild  Guild @relation(fields: [guildId], references: [id])

  usersFor     User[] @relation(name: "usersFor")
  usersAgainst User[] @relation(name: "usersAgainst")

  guildId  String
  authorId String

  createdAt         DateTime       @default(now())
  endsAt            DateTime
  proposalMessageId String?        @map("proposal_message_id")
  status            ProposalStatus @default(ACTIVE)
}

model RssFeed {
  id        String   @id @default(nanoid())
  guildId   String
  channelId String
  url       String
  name      String?

  lastCheckedAt DateTime?

  guild   Guild      @relation(fields: [guildId], references: [id], onDelete: Cascade)
  entries RssEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, url])
}

model RssEntry {
  id     String @id @default(nanoid())
  feedId String
  guid   String
  title  String
  link   String?
  description String? @db.Text
  author  String?
  publishedAt DateTime?

  feed RssFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([feedId, guid])
}

enum ProposalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}
